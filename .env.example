# ── Devansh OS configuration ───────────────────────────────────────────────
# Copy this file to `.env` and fill in your values. Nothing here is required to
# boot the app — providers without credentials simply stay idle.

# GitHub (coding heatmap). Personal Access Token with read access to your repos.
# For private contributions to count, use a classic token with `repo` scope, or
# a fine-grained token with read access to the repos you care about.
GITHUB_TOKEN=
GITHUB_USERNAME=

# LeetCode (DSA heatmap). Just your public username — no token needed.
# Uses the unofficial leetcode.com/graphql submission calendar.
LEETCODE_USERNAME=

# How often the background scheduler refreshes API providers (minutes).
POLL_MINUTES=30

# Local timezone used to bucket activity into days. IANA name, e.g.
# America/New_York, Europe/London, Asia/Kolkata.
TIMEZONE=Asia/Kolkata

# Host/port the server binds to. Defaults are local-only.
HOST=127.0.0.1
PORT=8000
